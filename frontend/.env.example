# Predictor Index frontend — public runtime config (inlined at build).
# Leave INDEXER/addresses unset to run on curated mock data (the default).
# NOTE: NEXT_PUBLIC_* are baked in at `next build`, so re-build after any change. Deploy runbook: docs/DEPLOY.md.

# Indexer REST base URL (e.g. Railway). Set ONLY if you host the Ponder indexer.
# DEPLOY GOTCHA: if this points at a dead URL (e.g. localhost:42069), live surfaces try it, fail,
# and degrade to the committed on-chain snapshot. Leave it BLANK unless a real indexer is hosted —
# blank serves the snapshot tier cleanly.
NEXT_PUBLIC_INDEXER_URL=

# Chain / RPC
NEXT_PUBLIC_RPC_URL=https://rpc.sepolia.mantle.xyz
NEXT_PUBLIC_CHAIN_ID=5003
NEXT_PUBLIC_EXPLORER_URL=https://sepolia.mantlescan.xyz
NEXT_PUBLIC_FAUCET_URL=https://faucet.sepolia.mantle.xyz

# Deployed contract addresses (from contracts/deployments/mantle-sepolia.json).
# After a RedeployFeed run, update COMPOSITE_FEED / DEMO_CONSUMER / YIELD_ALLOCATOR / RISK_MANAGER.
NEXT_PUBLIC_ADDR_COMPOSITE_FEED=
NEXT_PUBLIC_ADDR_DEMO_CONSUMER=
NEXT_PUBLIC_ADDR_AGENT_REGISTRY=
NEXT_PUBLIC_ADDR_PREDICTION_MARKET=
NEXT_PUBLIC_ADDR_YIELD_ALLOCATOR=
NEXT_PUBLIC_ADDR_RISK_MANAGER=
# Enables the real premium gate on /pricing (SubscriptionGate.tierOf / subscriptionExpiry).
NEXT_PUBLIC_ADDR_SUBSCRIPTION_GATE=

# Server-only (NOT NEXT_PUBLIC) — used by /api/narrate for plain-English forecast summaries.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1
