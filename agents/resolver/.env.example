# ─── Network ─────────────────────────────────────────────────────────────────
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz
CHAIN_ID=5003

# ─── Resolver hot wallet (small balance; NOT an agent key) ─────────────────────
# Earns the 2% resolver reward on each resolve(); needs only gas to start.
RESOLVER_PRIVATE_KEY=

# ─── Contract addresses ────────────────────────────────────────────────────────
# Optional overrides. If unset, loaded from contracts/deployments/<DEPLOY_NETWORK>.json.
ADDR_PREDICTION_MARKET=
ADDR_RESOLUTION_ENGINE=
DEPLOY_NETWORK=mantle-sepolia
# DEPLOYMENTS_FILE=

# ─── Cadence ───────────────────────────────────────────────────────────────────
# Loop interval in ms (default 1 min). Resolve is time-sensitive (predictions become
# resolvable at resolutionBlock), so poll faster than the refresher.
RESOLVE_INTERVAL_MS=60000
# Set true (or pass --once) for platform-managed cron: one pass then exit.
RESOLVE_ONCE=false
