# ─── Network ─────────────────────────────────────────────────────────────────
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz
CHAIN_ID=5003

# ─── Resolver hot wallet (small balance; NOT an agent key) ─────────────────────
# Earns the 2% resolver reward on each resolve(); needs only gas to start.
RESOLVER_PRIVATE_KEY=

# ─── Contract addresses ────────────────────────────────────────────────────────
# Optional overrides. If unset, loaded from contracts/deployments/<DEPLOY_NETWORK>.json.
ADDR_PREDICTION_MARKET=
ADDR_RESOLUTION_ENGINE=
DEPLOY_NETWORK=mantle-sepolia
# DEPLOYMENTS_FILE=

# ─── Pyth spot category (keeper mode) ──────────────────────────────────────────
# Set PYTH_ADDRESS to enable the keeper path: for MNT_USD_SPOT predictions the bot RECORDS the
# real Pyth price on-chain (pushing a signed Hermes update) before resolving. This wallet
# (RESOLVER_PRIVATE_KEY) MUST be set as the PythSpotResolver keeper at deploy (AddPythCategory KEEPER=).
# Leave PYTH_ADDRESS blank to run the plain resolve path only (category not deployed).
PYTH_ADDRESS=
# ADDR_PYTH_SPOT_RESOLVER=            # else read from deployments JSON (key: PythSpotResolver)
PYTH_FEED_ID=0x4e3037c822d852d79af3ac80e35eb420ee3b870dca49f9344a38ef4773fb0585  # MNT/USD (Hermes)
HERMES_URL=https://hermes.pyth.network

# ─── Cadence ───────────────────────────────────────────────────────────────────
# Loop interval in ms (default 1 min). Resolve is time-sensitive (predictions become
# resolvable at resolutionBlock), so poll faster than the refresher.
RESOLVE_INTERVAL_MS=60000
# Set true (or pass --once) for platform-managed cron: one pass then exit.
RESOLVE_ONCE=false
