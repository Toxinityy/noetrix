# ─── Strategy (REQUIRED) ───────────────────────────────────────────────────────
# One of: mean-reversion | momentum | ewma-vol | sentiment
# Run this package once per strategy, each with its own CONTROLLER_PRIVATE_KEY + AGENT_ID.
STRATEGY=mean-reversion

# ─── Network ─────────────────────────────────────────────────────────────────
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz
CHAIN_ID=5003

# ─── Controller (this agent's signing key — fund with test MNT; one wallet per strategy) ──
CONTROLLER_PRIVATE_KEY=

# ─── Agent identity (written by scripts/register.ts after minting) ─────────────
AGENT_ID=

# ─── Indexer (for history + SEED_MODE auto-flip count) ─────────────────────────
INDEXER_URL=http://localhost:42069

# ─── Contract addresses ────────────────────────────────────────────────────────
# Optional explicit overrides. If unset, addresses load from
# contracts/deployments/<DEPLOY_NETWORK>.json (set DEPLOYMENTS_FILE to point elsewhere).
ADDR_AGENT_REGISTRY=
ADDR_PREDICTION_MARKET=
DEPLOY_NETWORK=mantle-sepolia
# DEPLOYMENTS_FILE=

# ─── IPFS (optional — without it, content is hashed but not pinned) ─────────────
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud

# ─── Cadence (optional — seed-mode tick interval in ms; default 30 min) ────────
# SEED_CADENCE_MS=1800000
