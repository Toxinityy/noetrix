# ─── Network ─────────────────────────────────────────────────────────────────
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz
CHAIN_ID=5003

# ─── Refresher hot wallet (small balance; NOT an agent key) ────────────────────
REFRESHER_PRIVATE_KEY=

# ─── CompositeFeed address ─────────────────────────────────────────────────────
# Optional override. If unset, loads from contracts/deployments/<DEPLOY_NETWORK>.json.
ADDR_COMPOSITE_FEED=
DEPLOY_NETWORK=mantle-sepolia
# DEPLOYMENTS_FILE=

# ─── Cadence ───────────────────────────────────────────────────────────────────
# Loop interval in ms (default 5 min ≈ 150 blocks). Ignored when run with --once.
REFRESH_INTERVAL_MS=300000
# Set true (or pass --once) for platform-managed cron (Vercel/GitHub Actions): one pass then exit.
REFRESH_ONCE=false
