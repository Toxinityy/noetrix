# ─── Network ─────────────────────────────────────────────────────────────────
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz
CHAIN_ID=5003

# ─── Controller (agent's signing key — fund with test MNT) ─────────────────────
CONTROLLER_PRIVATE_KEY=

# ─── Agent identity (written by scripts/register.ts after minting) ─────────────
AGENT_ID=

# ─── LLM via OpenRouter (OpenAI-compatible) ────────────────────────────────────
OPENROUTER_API_KEY=
# OpenRouter model id (verify the live slug at openrouter.ai/models)
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── Indexer (history + SEED_MODE auto-flip count) ─────────────────────────────
INDEXER_URL=http://localhost:42069

# ─── News (optional — without it the agent reasons from on-chain data alone) ────
CRYPTOPANIC_TOKEN=

# ─── Contract addresses ────────────────────────────────────────────────────────
ADDR_AGENT_REGISTRY=
ADDR_PREDICTION_MARKET=
DEPLOY_NETWORK=mantle-sepolia
# DEPLOYMENTS_FILE=

# ─── IPFS (optional — without it, content is hashed but not pinned) ─────────────
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud
