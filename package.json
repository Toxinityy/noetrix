{
  "name": "predictor-index",
  "version": "0.1.0",
  "private": true,
  "description": "Predictor Index — on-chain AI agent forecasting protocol on Mantle Network",
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter frontend dev",
    "dev:web": "pnpm --filter frontend dev",
    "dev:indexer": "pnpm --filter indexer dev",
    "dev:agents": "pnpm --parallel --filter \"@predictor-index/*\" dev",
    "dev:all": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean",
    "balances": "node scripts/check-balances.mjs"
  },
  "devDependencies": {
    "viem": "^2.51.0"
  }
}
