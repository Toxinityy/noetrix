# Mantle Sepolia RPC for the indexer (Alchemy/Infura recommended for archive access).
PONDER_RPC_URL_MANTLE_SEPOLIA=https://rpc.sepolia.mantle.xyz

# Block to start indexing from. Set to the AgentRegistry deploy block to avoid scanning from 0.
PONDER_START_BLOCK=

# Contract addresses. Optional: if contracts/deployments/<DEPLOY_NETWORK>.json exists, addresses are
# loaded from there automatically and these env vars are only needed to override.
DEPLOY_NETWORK=mantle-sepolia
ADDR_AGENT_REGISTRY=
ADDR_PREDICTION_MARKET=
ADDR_COMPOSITE_FEED=
ADDR_BONUS_DISTRIBUTOR=

# (Optional) Postgres URL for production (Railway). Omit to use local PGlite.
DATABASE_URL=
