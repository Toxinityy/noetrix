# deploy/keeper.env — secrets for deploy/keeper.sh (gitignored; copy this file to keeper.env)

# Signing key for setFearGreed + poke. Simplest: reuse the deployer/owner key (owner passes
# onlyKeeper automatically). If you use a separate hot wallet, the OWNER must authorize it once:
#   cast send <SentimentOracle> "setKeeper(address,bool)" <keeperAddr> true \
#     --rpc-url $MANTLE_SEPOLIA_RPC --private-key <ownerKey>
KEEPER_PRIVATE_KEY=0x...

MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz

# Optional (default mantle-sepolia) — picks contracts/deployments/<net>.json
# DEPLOY_NETWORK=mantle-sepolia
