# ─── RPC endpoints ───────────────────────────────────────────────────────────
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz
MANTLE_MAINNET_RPC=https://rpc.mantle.xyz

# ─── Deployer ────────────────────────────────────────────────────────────────
# Hot key used by Deploy.s.sol / SeedRates.s.sol / SmokeTest.s.sol. Fund with test MNT.
PRIVATE_KEY=

# ─── Verification ────────────────────────────────────────────────────────────
MANTLESCAN_API_KEY=

# ─── Optional overrides ──────────────────────────────────────────────────────
# Network name used for deployments/<DEPLOY_NETWORK>.json (default: mantle-sepolia)
DEPLOY_NETWORK=mantle-sepolia
# SeedRates tuning
MOCK_METH_ORACLE=
BASE_BLOCK=
SEED_DAYS=14
DAILY_GROWTH_PPM=8

# ─── AddPythCategory.s.sol (live Pyth spot category) ─────────────────────────
# Deployed Pyth pull-oracle on the target chain. CONFIRM the Mantle Sepolia address before broadcast
# (Mantle mainnet is 0xA2aa501b19aff244D90cc15a4Cf739D2725B5729).
PYTH_ADDRESS=
# bytes32 price-feed id (MNT/USD confirmed via Hermes; ETH/USD fallback 0xff61491a…fd0ace).
PYTH_FEED_ID=0x4e3037c822d852d79af3ac80e35eb420ee3b870dca49f9344a38ef4773fb0585
# Resolver-bot hot wallet allowed to record() snapshots. Defaults to the deployer if unset.
KEEPER=
